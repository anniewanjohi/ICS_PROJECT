# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration (MSSQL) - Windows Authentication
DB_HOST=.\\SQLEXPRESS
DB_PORT=1433
DB_NAME=ICS_PROJECT
DB_TRUSTED_CONNECTION=true
# Remove DB_USER and DB_PASSWORD when using Windows Authentication

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=8h

# Frontend URL
FRONTEND_URL=http://localhost:3000